{
  "name": "shader-validator-gs",
  "displayName": "Shader validator GS",
  "description": "HLSL / GLSL / WGSL language server for vscode",
  "icon": "res/logo-shader-validator-gs.png",
  "galleryBanner": {
    "color": "#9ad0ff",
    "theme": "light"
  },
  "version": "1.3.2",
  "server_version": "1.3.1",
  "publisher": "antaalt",
  "repository": {
    "type": "git",
    "url": "https://github.com/antaalt/shader-validator"
  },
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "shader",
    "lsp",
    "hlsl",
    "glsl",
    "wgsl"
  ],
  "activationEvents": [
    "onCommand:shader-validator-gs.validateFile",
    "onLanguage:glsl",
    "onLanguage:wgsl",
    "onLanguage:hlsl"
  ],
  "main": "./dist/node/extension",
  "browser": "./dist/web/extension",
  "contributes": {
    "languages": [
      {
        "id": "hlsl",
        "extensions": [
          ".hlsl",
          ".hlsli",
          ".fx",
          ".fxh",
          "ush",
          "usf"
        ],
        "icon": {
          "light": "./res/icons/hlsl-icon.svg",
          "dark": "./res/icons/hlsl-icon.svg"
        },
        "configuration": "./language-configuration.json"
      },
      {
        "id": "glsl",
        "extensions": [
          ".glsl",
          ".vert",
          ".frag",
          ".mesh",
          ".task",
          ".comp",
          ".compp",
          ".geom",
          ".tesc",
          ".tese"
        ],
        "icon": {
          "light": "./res/icons/glsl-icon.svg",
          "dark": "./res/icons/glsl-icon.svg"
        },
        "configuration": "./language-configuration.json"
      },
      {
        "id": "wgsl",
        "extensions": [
          ".wgsl"
        ],
        "icon": {
          "light": "./res/icons/wgsl-icon.svg",
          "dark": "./res/icons/wgsl-icon.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hlsl",
        "scopeName": "source.hlsl",
        "path": "./syntaxes/hlsl.tmLanguage.json"
      },
      {
        "language": "glsl",
        "scopeName": "source.glsl",
        "path": "./syntaxes/glsl.tmLanguage.json"
      },
      {
        "language": "wgsl",
        "scopeName": "source.wgsl",
        "path": "./syntaxes/wgsl.tmLanguage.json"
      }
    ],
    "configuration": [
      {
        "title": "Common",
        "properties": {
          "shader-validator-gs.validate": {
            "description": "Validate shader as you type with common validator API.",
            "type": "boolean",
            "default": true
          },
          "shader-validator-gs.symbols": {
            "description": "Provide symbol inspection with providers (goto, hover, completion...)",
            "type": "boolean",
            "default": true
          },
          "shader-validator-gs.symbolDiagnostics": {
            "description": "Provide diagnostics when symbol provider has issues.",
            "type": "boolean",
            "default": false
          },
          "shader-validator-gs.updateSymbolsOnVariantUpdate": {
            "description": "Automatically update the symbols on variant update. Will trigger a save on the file.",
            "type": "boolean",
            "default": true
          },
          "shader-validator-gs.experimentalMacroExpansion": {
            "description": "Expand macro to be part of the document symbols. Experimental feature, might be unstable.",
            "type": "boolean",
            "default": false
          },
          "shader-validator-gs.dependencyContextDiagnostics": {
            "description": "Look for a main file if we are on an include file to automatically resolve its context.",
            "type": "boolean",
            "default": false
          },
          "shader-validator-gs.severity": {
            "type": "string",
            "description": "Minimum linting severity. Set it lower to display some hints aswell. Might not be supported by all languages.",
            "default": "info",
            "enum": [
              "none",
              "error",
              "warning",
              "info",
              "hint"
            ]
          },
          "shader-validator-gs.includes": {
            "description": "Include paths to look up for includes.",
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "shader-validator-gs.clientSideIncludes": {
            "description": "Resolve #include directives client-side before sending documents to the language server. Diagnostics are automatically remapped to the correct source files.",
            "type": "boolean",
            "default": false
          },
          "shader-validator-gs.defines": {
            "description": "Preprocessor variables and values.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "shader-validator-gs.stageDefine.vertex": {
            "description": "Preprocessor variables for vertex shader stage.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "shader-validator-gs.stageDefine.fragment": {
            "description": "Preprocessor variables for fragment shader stage.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "shader-validator-gs.stageDefine.compute": {
            "description": "Preprocessor variables for compute shader stage.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "shader-validator-gs.stageDefine.geometry": {
            "description": "Preprocessor variables for geometry shader stage.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "shader-validator-gs.stageDefine.tesselationControl": {
            "description": "Preprocessor variables for tesselation control shader stage.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "shader-validator-gs.stageDefine.tesselationEvaluation": {
            "description": "Preprocessor variables for tesselation evaluation shader stage.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "shader-validator-gs.stageDefine.mesh": {
            "description": "Preprocessor variables for mesh shader stage.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "shader-validator-gs.stageDefine.task": {
            "description": "Preprocessor variables for task shader stage.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "shader-validator-gs.stageDefine.rayGeneration": {
            "description": "Preprocessor variables for ray generation shader stage.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "shader-validator-gs.stageDefine.closestHit": {
            "description": "Preprocessor variables for closest hit shader stage.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "shader-validator-gs.stageDefine.anyHit": {
            "description": "Preprocessor variables for any hit shader stage.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "shader-validator-gs.stageDefine.callable": {
            "description": "Preprocessor variables for callable shader stage.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "shader-validator-gs.stageDefine.miss": {
            "description": "Preprocessor variables for miss shader stage.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "shader-validator-gs.stageDefine.intersect": {
            "description": "Preprocessor variables for intersect shader stage.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "shader-validator-gs.pathRemapping": {
            "description": "Remap virtual path starting with / to an absolute path.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "shader-validator-gs.serverPath": {
            "description": "Use an external server instead of the bundled ones.",
            "type": "string",
            "default": ""
          },
          "shader-validator-gs.configOverride": {
            "description": "Override configuration with a path to a specific configuration file.",
            "type": "string",
            "default": ""
          },
          "shader-validator-gs.useWasiServer": {
            "description": "Use the wasi server instead of the native server. Only working for platform where DXC is available.",
            "type": "boolean",
            "default": false
          }
        }
      },
      {
        "title": "Hlsl",
        "properties": {
          "shader-validator-gs.hlsl.enabled": {
            "description": "Enable HLSL support for language server.",
            "type": "boolean",
            "default": true
          },
          "shader-validator-gs.hlsl.shaderModel": {
            "type": "string",
            "description": "Shader model targeted for DXC HLSL (DXC only support up to sm 6.0).",
            "default": "ShaderModel6_8",
            "enum": [
              "ShaderModel6",
              "ShaderModel6_1",
              "ShaderModel6_2",
              "ShaderModel6_3",
              "ShaderModel6_4",
              "ShaderModel6_5",
              "ShaderModel6_6",
              "ShaderModel6_7",
              "ShaderModel6_8"
            ],
            "enumItemLabels": [
              "sm 6.0",
              "sm 6.1",
              "sm 6.2",
              "sm 6.3",
              "sm 6.4",
              "sm 6.5",
              "sm 6.6",
              "sm 6.7",
              "sm 6.8"
            ]
          },
          "shader-validator-gs.hlsl.version": {
            "type": "string",
            "description": "HLSL version for DXC.",
            "default": "V2021",
            "enum": [
              "V2016",
              "V2017",
              "V2018",
              "V2021"
            ],
            "enumItemLabels": [
              "2016",
              "2017",
              "2018",
              "2021"
            ]
          },
          "shader-validator-gs.hlsl.enable16bitTypes": {
            "type": "boolean",
            "description": "Enable 16 bits types. Only supported with sm >= 6.2 & HLSL version >= 2018.",
            "default": false
          },
          "shader-validator-gs.hlsl.spirv": {
            "type": "boolean",
            "description": "Allow spirv syntax in shader code.",
            "default": false
          }
        }
      },
      {
        "title": "Glsl",
        "properties": {
          "shader-validator-gs.glsl.enabled": {
            "description": "Enable GLSL support for language server.",
            "type": "boolean",
            "default": true
          },
          "shader-validator-gs.glsl.targetClient": {
            "type": "string",
            "description": "Shader client for GLSL.",
            "default": "Vulkan1_3",
            "enum": [
              "Vulkan1_0",
              "Vulkan1_1",
              "Vulkan1_2",
              "Vulkan1_3",
              "OpenGL450"
            ],
            "enumItemLabels": [
              "Vulkan 1.0",
              "Vulkan 1.1",
              "Vulkan 1.2",
              "Vulkan 1.3",
              "OpenGL"
            ]
          },
          "shader-validator-gs.glsl.preamble": {
            "type": "string",
            "description": "Specify a path to a file containing a preamble for all GLSL files.",
            "default": ""
          },
          "shader-validator-gs.glsl.spirvVersion": {
            "type": "string",
            "description": "SPIRV version targeted for GLSL.",
            "default": "SPIRV1_6",
            "enum": [
              "SPIRV1_0",
              "SPIRV1_1",
              "SPIRV1_2",
              "SPIRV1_3",
              "SPIRV1_4",
              "SPIRV1_5",
              "SPIRV1_6"
            ],
            "enumItemLabels": [
              "Spirv 1.0",
              "Spirv 1.1",
              "Spirv 1.2",
              "Spirv 1.3",
              "Spirv 1.4",
              "Spirv 1.5",
              "Spirv 1.6"
            ]
          }
        }
      },
      {
        "title": "Wgsl",
        "properties": {
          "shader-validator-gs.wgsl.enabled": {
            "description": "Enable WGSL support for language server.",
            "type": "boolean",
            "default": true
          }
        }
      },
      {
        "title": "Debug",
        "properties": {
          "shader-validator-gs.trace.server": {
            "type": "string",
            "scope": "window",
            "enum": [
              "off",
              "messages",
              "verbose"
            ],
            "enumDescriptions": [
              "No traces",
              "Error only",
              "Full log"
            ],
            "default": "off",
            "description": "Trace requests to the shader-language-server (this is usually overly verbose and not recommended for regular users)."
          }
        }
      }
    ],
    "commands": [
      {
        "command": "shader-validator-gs.showLogs",
        "title": "Show logs",
        "category": "Shader validator",
        "icon": "$(terminal)"
      },
      {
        "command": "shader-validator-gs.startServer",
        "title": "Start server",
        "category": "Shader validator",
        "icon": "$(debug-start)"
      },
      {
        "command": "shader-validator-gs.stopServer",
        "title": "Stop server",
        "category": "Shader validator",
        "icon": "$(debug-stop)"
      },
      {
        "command": "shader-validator-gs.restartServer",
        "title": "Restart server",
        "category": "Shader validator",
        "icon": "$(debug-restart)"
      },
      {
        "command": "shader-validator-gs.validateFile",
        "title": "Validate file",
        "category": "Shader validator",
        "icon": "$(check)"
      },
      {
        "command": "shader-validator-gs.dumpAst",
        "title": "Dump ast for debug",
        "category": "Shader validator",
        "icon": "$(list-tree)"
      },
      {
        "command": "shader-validator-gs.dumpDependency",
        "title": "Dump dependency tree for debug",
        "category": "Shader validator",
        "icon": "$(list-tree)"
      },
      {
        "command": "shader-validator-gs.addCurrentFile",
        "title": "Add current file",
        "category": "Shader validator",
        "icon": "$(add)",
        "enablement": "view == shader-validator-variants"
      },
      {
        "command": "shader-validator-gs.addCurrentFileVariant",
        "title": "Add a shader variant for current file",
        "category": "Shader validator",
        "icon": "$(add)"
      },
      {
        "command": "shader-validator-gs.editMenu",
        "title": "Edit",
        "category": "Shader validator",
        "icon": "$(edit)",
        "enablement": "view == shader-validator-variants"
      },
      {
        "command": "shader-validator-gs.addMenu",
        "title": "Add",
        "category": "Shader validator",
        "icon": "$(add)",
        "enablement": "view == shader-validator-variants"
      },
      {
        "command": "shader-validator-gs.deleteMenu",
        "title": "Delete",
        "category": "Shader validator",
        "icon": "$(trash)",
        "enablement": "view == shader-validator-variants"
      },
      {
        "command": "shader-validator-gs.gotoShaderEntryPoint",
        "title": "Go to shader entry point",
        "category": "Shader validator",
        "icon": "$(arrow-right)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "shader-validator-gs.gotoShaderEntryPoint",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "shader-validator-gs.addCurrentFile",
          "when": "view == shader-validator-variants && editorIsOpen",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "shader-validator-gs.addMenu",
          "group": "inline@1",
          "when": "view == shader-validator-variants && (viewItem == file || viewItem == includeList || viewItem == defineList)"
        },
        {
          "command": "shader-validator-gs.editMenu",
          "group": "inline@2",
          "when": "view == shader-validator-variants && (viewItem == variant || viewItem == include || viewItem == define || viewItem == stage)"
        },
        {
          "command": "shader-validator-gs.deleteMenu",
          "group": "inline@3",
          "when": "view == shader-validator-variants && (viewItem == variant || viewItem == include || viewItem == define || viewItem == file)"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shader-validator",
          "title": "Shader validator",
          "icon": "res/icons/hlsl-icon.svg"
        }
      ]
    },
    "views": {
      "shader-validator": [
        {
          "id": "shader-validator-variants",
          "name": "Shader variants",
          "icon": "res/icons/hlsl-icon.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "shader-validator-variants",
        "contents": "In order to setup a shader variant, you can add a currently opened shader file & configure it from here.\n[Add Current File](command:shader-validator-gs.addCurrentFile)\nShader variant allow you to define a context and an entry point for shader for a better validation & symbol providing experience.",
        "when": "workbenchState != empty && editorIsOpen"
      },
      {
        "view": "shader-validator-variants",
        "contents": "Open a file to be able to add it as a shader variant.",
        "when": "workbenchState != empty && !editorIsOpen"
      },
      {
        "view": "shader-validator-variants",
        "contents": "Open a file to be able to add it as a shader variant.",
        "when": "workbenchState == empty"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "webpack --mode production",
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "open-in-browser": "vscode-test-web --extensionDevelopmentPath=. .",
    "pretest": "webpack --mode development && tsc -p . --outDir out",
    "test": "node ./out/test/runTest.js",
    "test-wasi": "node ./out/test/runTest.js -- --useWasiServer",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "1.88.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/test-web": "^0.0.60",
    "eslint": "^9.39.2",
    "glob": "^8.0.3",
    "mocha": "^10.1.0",
    "ts-loader": "^9.5.1",
    "typescript": "^4.9.3",
    "webpack": "^5.93.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@vscode/wasm-wasi": "^1.0.1",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "vscode-languageclient": "^10.0.0-next.3"
  }
}
